# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Market data
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=

# LLM provider and model overrides
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini

# Execution mode: llm_assisted (default) or quant_strict
# TRADINGAGENTS_EXECUTION_MODE=llm_assisted

# Directory overrides (defaults to ~/.tradingagents/)
# TRADINGAGENTS_RESULTS_DIR=
# TRADINGAGENTS_CACHE_DIR=
# TRADINGAGENTS_INTRADAY_CACHE_DIR=

# Intraday session default: regular, extended, or crypto
# TRADINGAGENTS_INTRADAY_SESSION=regular

# Quant prefilter cache TTL in days
# TRADINGAGENTS_QUANT_CACHE_TTL_DAYS=1
