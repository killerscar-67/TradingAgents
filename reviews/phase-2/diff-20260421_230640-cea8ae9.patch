++            score = float(parsed.get("score", float("-inf")))
++        except (TypeError, ValueError):
++            score = float("-inf")
++
++        scored.append(
++            {
++                "symbol": symbol,
++                "score": score,
++                "signal": parsed.get("signal", "unknown"),
++                "confidence": parsed.get("confidence"),
++                "summary": parsed.get("summary", ""),
++                "error": error,
++                "cache_hit": cache_hit,
++                "raw": parsed,
