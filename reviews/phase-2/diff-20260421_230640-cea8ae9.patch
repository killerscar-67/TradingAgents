++) -> Dict[str, List[Dict[str, Any]]]:
++    """Rank a ticker universe with the quant tool and select top-N for LLM analysis."""
++    quant_kwargs = quant_kwargs or {}
++    cleaned = []
++    seen = set()
++    for ticker in tickers:
