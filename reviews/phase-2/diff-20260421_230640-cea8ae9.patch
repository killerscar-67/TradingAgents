++
++    ranked = sorted(scored, key=lambda item: (item["error"] is not None, -item["score"]))
++    selected = [item for item in ranked if item["error"] is None][: max(int(top_n), 1)]
++
++    return {
++        "ranked": ranked,
++        "selected": selected,
++    }
